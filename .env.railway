# Railway Environment Variables
# Set these in Railway dashboard > Variables

# === REQUIRED ===

# Database (auto-set by Railway Postgres addon)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# App authentication — shared beta password hash
# Generate with: python -c "import hashlib; print(hashlib.sha256(b'YOUR_BETA_PASSWORD').hexdigest())"
APP_PASSWORD_HASH=

# OpenAI key for Standard analysis mode
OPENAI_API_KEY=

# === OPTIONAL ===

# CORS — set to your Railway app URL (auto-detected if not set)
# ALLOWED_ORIGINS=https://your-app.up.railway.app

# Rate limits
STANDARD_DAILY_LIMIT=10
DEEP_DIVE_ENABLED=false

# Financial data API (optional, improves US stock data)
# FINANCIAL_DATASETS_API_KEY=
