# =============================================================================
#  ai-hedge-fund — example environment configuration
#  Copy to `.env` and fill in real values. NEVER commit `.env` with real keys.
# =============================================================================

# --- LLM providers (uncomment + fill in any you intend to use) ---------------
# Anthropic — claude-3-5-haiku, claude-3-5-sonnet, claude-3-7-sonnet, etc.
# https://console.anthropic.com/
# ANTHROPIC_API_KEY=<PLACEHOLDER>

# DeepSeek — deepseek-chat, deepseek-reasoner
# https://platform.deepseek.com/
# DEEPSEEK_API_KEY=<PLACEHOLDER>

# Google Gemini — gemini-2.5-flash, gemini-2.5-pro
# https://ai.dev/
# GOOGLE_API_KEY=<PLACEHOLDER>

# Groq — llama-3.3-70b-versatile, etc.
# https://console.groq.com/
# GROQ_API_KEY=<PLACEHOLDER>

# OpenAI — gpt-4o, gpt-4.5, o1, o3-mini, etc.
# https://platform.openai.com/
# OPENAI_API_KEY=<PLACEHOLDER>

# OpenRouter — access multiple providers via one key
# https://openrouter.ai/
# OPENROUTER_API_KEY=<PLACEHOLDER>

# --- Market data --------------------------------------------------------------
# Financial Datasets — required for non-free tickers. Free tickers: AAPL, GOOGL, MSFT, NVDA, TSLA.
# https://financialdatasets.ai/
# FINANCIAL_DATASETS_API_KEY=<PLACEHOLDER>

# --- Web service (Phase F1+) --------------------------------------------------
# Single-token bearer auth for the FastAPI server. Generate with: openssl rand -hex 32
# AHF_APP_TOKEN=<PLACEHOLDER>

# CORS allowlist (comma-separated). Default for dev: http://localhost:5173
# AHF_CORS_ORIGINS=http://localhost:5173

# Path to the SQLite database file (default: ./data/runs.db)
# AHF_DB_URL=sqlite:///./data/runs.db

# Log level: DEBUG | INFO | WARNING | ERROR
# AHF_LOG_LEVEL=INFO
